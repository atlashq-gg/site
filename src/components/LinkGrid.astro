---
import { links } from "../data/links";
import LinkCard from "./LinkCard.astro";
---

<section id="links" class="mx-auto w-full max-w-6xl px-6 pt-10 pb-12 sm:pt-12 sm:pb-14">
  <div class="mb-10 text-center">
    <h2
      class="font-display text-3xl font-bold uppercase tracking-wide sm:text-4xl"
    >
      Quick Links
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-muted">
      Everything you need, in one place.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {links.map((item) => <LinkCard item={item} />)}
  </div>
</section>
