---
import { Image } from "astro:assets";
import { regiment, faction } from "../config";
import { discord } from "../data/links";
import broadside from "../assets/broadside.png";
import { activeCrest } from "../lib/crest";

// The crest + eyebrow label follow the active faction (set at build time in
// src/config.ts).
const logo = activeCrest;
const factionName = faction === "warden" ? "Warden" : "Colonial";
---

<header
  class="relative z-0 flex min-h-[101svh] flex-col items-center justify-center px-6 pt-20 pb-[17svh] text-center"
>
  <!--
    SPLASH ART (broadside.png). Fills the hero and scrolls with the page; its
    bottom edge dissolves into the background via a mask fade on the image
    (see the <style> block below).
  -->
  <div class="hero-art" aria-hidden="true">
    <Image
      src={broadside}
      alt=""
      width={2560}
      quality={78}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="hero-art__img"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-3xl">
    <Image
      src={logo}
      alt={`${regiment.name} regiment crest`}
      width={640}
      height={640}
      class="mx-auto mb-6 h-52 w-52 drop-shadow-[0_6px_16px_rgba(0,0,0,0.65)] sm:h-[clamp(13rem,34svh,20rem)] sm:w-[clamp(13rem,34svh,20rem)]"
    />

    <!--
      Eyebrow label. On Warden builds it plays the same joke as the Warden crest
      (which covers the Colonial signature with a pinned sticky note): the word
      "Colonial" stays in the label, with a CSS sticky note reading "Warden"
      slapped over it. Screen readers just hear the plain corrected label.
    -->
    {
      faction === "warden" ? (
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-accent-strong">
          <span class="sr-only">Warden Foxhole Regiment</span>
          <span aria-hidden="true">
            <span class="note-anchor">
              Colonial<span class="sticky-note">Warden</span>
            </span>{" "}
            Foxhole Regiment
          </span>
        </p>
      ) : (
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-accent-strong">
          {factionName} Foxhole Regiment
        </p>
      )
    }

    <h1
      class="hero-title font-display text-5xl font-bold uppercase leading-none tracking-tight sm:text-7xl"
    >
      {regiment.name}
    </h1>

    <p class="hero-tagline mx-auto mt-6 max-w-xl text-lg text-muted">
      {regiment.tagline}
    </p>

    <div class="mt-10 flex flex-col items-center gap-3">
      <a
        href={discord.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-accent px-8 py-4 text-lg font-semibold uppercase tracking-wide text-accent-contrast shadow-lg transition hover:bg-accent-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-strong"
      >
        {discord.label}
      </a>
      <span class="hero-tagline max-w-md text-sm text-muted">{discord.blurb}</span>
    </div>

    <!-- Scroll cue sits just below the CTA, centered with the content. -->
    <a
      href="#links"
      class="mt-12 inline-block text-sm uppercase tracking-widest text-muted transition hover:text-text"
      aria-label="Jump to quick links"
    >
      ↓ Quick Links
    </a>
  </div>
</header>

<style>
  /*
    Splash art: fills the top of the hero (var --hero-art-h tall) and scrolls
    with the page. Its bottom edge is faded out with a mask, so the picture
    dissolves into the page background (--bg) with no visible line.
  */
  .hero-art {
    --hero-art-h: 100svh; /* how much of the viewport the splash fills */
    --hero-fade-start: 80%; /* where the picture begins fading, top→bottom */

    position: absolute;
    inset: 0 0 auto 0;
    height: var(--hero-art-h);
    z-index: 0;
    background: var(--bg);
  }

  .hero-art__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    /* Fade the picture's bottom edge out so it dissolves into --bg below. */
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 var(--hero-fade-start),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      #000 var(--hero-fade-start),
      transparent 100%
    );
  }

  /*
    Warden-only sticky note over the word "Colonial" in the eyebrow label —
    mirrors the pinned note covering the Colonial signature on the Warden crest.
    Handwriting relies on system fonts (Segoe Print → Comic Sans → cursive);
    the rotation, paper, and pin carry the effect if none are available.
  */
  .note-anchor {
    position: relative;
    display: inline-block;
  }
  .sticky-note {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -52%) rotate(-5deg);
    background: linear-gradient(#f2e388, #e6d16b);
    color: #223;
    padding: 2px 10px 3px;
    font-family: "Segoe Print", "Comic Sans MS", cursive;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    white-space: nowrap;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.5);
  }
  /* The red push-pin, matching the one on the crest's note. */
  .sticky-note::before {
    content: "";
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #e05c50, #8d2f27);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
  }

  /* Belt-and-suspenders legibility for the headline + supporting copy. */
  .hero-title {
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.55);
  }
  .hero-tagline {
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.6);
  }
</style>
