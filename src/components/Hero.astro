---
import { Image } from "astro:assets";
import { regiment, faction } from "../config";
import { discord } from "../data/links";
import broadside from "../assets/broadside.png";
import { activeCrest } from "../lib/crest";

// The crest + eyebrow label follow the active faction (set at build time in
// src/config.ts).
const logo = activeCrest;
const factionName = faction === "warden" ? "Warden" : "Colonial";
---

<header
  class="relative z-0 flex min-h-[88svh] flex-col items-center justify-center px-6 py-20 text-center"
>
  <!--
    SPLASH ART. Fixed to the viewport so page content scrolls up over it.
    The image is the source of truth; .hero-art::after lays a dark gradient on
    top so the centered title/CTA stay legible. To change the art: swap the
    broadside.png import above (any wide, dark image works best).
  -->
  <div class="hero-art" aria-hidden="true">
    <Image
      src={broadside}
      alt=""
      width={2560}
      quality={78}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="hero-art__img"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-3xl">
    <Image
      src={logo}
      alt={`${regiment.name} regiment crest`}
      width={360}
      height={360}
      class="mx-auto mb-6 h-28 w-28 drop-shadow-[0_6px_16px_rgba(0,0,0,0.65)] sm:h-36 sm:w-36"
    />

    <p
      class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-accent-strong"
    >
      {factionName} Foxhole Regiment
    </p>

    <h1
      class="hero-title font-display text-5xl font-bold uppercase leading-none tracking-tight sm:text-7xl"
    >
      {regiment.name}
    </h1>

    <p class="hero-tagline mx-auto mt-6 max-w-xl text-lg text-muted">
      {regiment.tagline}
    </p>

    <div class="mt-10 flex flex-col items-center gap-3">
      <a
        href={discord.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-accent px-8 py-4 text-lg font-semibold uppercase tracking-wide text-accent-contrast shadow-lg transition hover:bg-accent-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-strong"
      >
        {discord.label}
      </a>
      <span class="hero-tagline max-w-md text-sm text-muted">{discord.blurb}</span>
    </div>
  </div>

  <!-- Scroll cue pinned to the bottom of the splash -->
  <a
    href="#links"
    class="absolute bottom-20 left-1/2 z-10 -translate-x-1/2 text-sm uppercase tracking-widest text-muted transition hover:text-text"
    aria-label="Jump to quick links"
  >
    ↓ Quick Links
  </a>
</header>

<style>
  /* Splash art, fixed to the viewport so content scrolls over it. */
  .hero-art {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-art__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias slightly upward so the lit ships/water stay in frame on tall screens. */
    object-position: center 42%;
  }

  /* Dark overlay for text legibility + a fade into --bg at the bottom so the
     splash blends into the content panel that scrolls over it. */
  .hero-art::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 95% 70% at 50% 44%,
        color-mix(in srgb, var(--bg) 55%, transparent),
        transparent 70%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg) 35%, transparent) 0%,
        transparent 30%,
        transparent 62%,
        var(--bg) 100%
      );
  }

  /* Belt-and-suspenders legibility for the headline + supporting copy. */
  .hero-title {
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.55);
  }
  .hero-tagline {
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.6);
  }
</style>
