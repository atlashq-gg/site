---
import { intro, activities } from "../data/content";
---

<section id="about" class="mx-auto w-full max-w-3xl px-6 pt-12 pb-20 text-center sm:pt-14 sm:pb-24">
  <h2 class="font-display text-3xl font-bold uppercase tracking-wide sm:text-4xl">
    {intro.heading}
  </h2>

  <p class="mt-6 text-lg leading-relaxed text-muted">{intro.body}</p>

  <p class="mt-8 font-display text-xl uppercase tracking-wide text-accent-strong">
    {intro.motto}
  </p>

  <!-- Activities, woven in as a simple list rather than cards -->
  <p class="mt-12 text-muted">{activities.intro}</p>

  <ul
    class="mx-auto mt-6 max-w-xl divide-y divide-border border-y border-border text-left"
  >
    {
      activities.items.map((a) => (
        <li class="flex flex-col gap-1 py-4 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
          <span class="font-display text-lg font-semibold uppercase tracking-wide text-accent-strong">
            {a.title}
          </span>
          <span class="text-sm italic text-muted sm:text-right">{a.detail}</span>
        </li>
      ))
    }
  </ul>
</section>
