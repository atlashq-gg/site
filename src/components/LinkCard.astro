---
import type { LinkItem } from "../data/links";

interface Props {
  item: LinkItem;
}

const { item } = Astro.props;
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex h-full flex-col rounded-lg border border-border bg-surface p-5 transition hover:-translate-y-0.5 hover:border-accent hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-strong"
>
  {
    item.category && (
      <span class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-strong">
        {item.category}
      </span>
    )
  }
  <h3
    class="font-display text-xl font-semibold uppercase tracking-wide text-text"
  >
    {item.title}
  </h3>
  <p class="mt-1 text-sm leading-relaxed text-muted">{item.description}</p>

  <span
    class="mt-auto pt-4 text-sm font-medium text-muted transition group-hover:text-accent-strong"
    aria-hidden="true"
  >
    Open →
  </span>
</a>
